ickkode"},"content":"---","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":5,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":6,"author":{"gitId":"yellowbrickkode"},"content":"### Project: AddressBook Level 3","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":7,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":8,"author":{"gitId":"yellowbrickkode"},"content":"AddressBook - Level 3 is a desktop address book application used for teaching Software Engineering principles. The user interacts with it using a CLI, and it has a GUI created with JavaFX. It is written in Java, and has about 10 kLoC.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":9,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":10,"author":{"gitId":"yellowbrickkode"},"content":"Given below are my contributions to the project.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":11,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":12,"author":{"gitId":"yellowbrickkode"},"content":"* **New Feature**: Added the ability to undo/redo previous commands.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":13,"author":{"gitId":"yellowbrickkode"},"content":"  * What it does: allows the user to undo all previous commands one at a time. Preceding undo commands can be reversed by using the redo command.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":14,"author":{"gitId":"yellowbrickkode"},"content":"  * Justification: This feature improves the product significantly because a user can make mistakes in commands and the app should provide a convenient way to rectify them.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":15,"author":{"gitId":"yellowbrickkode"},"content":"  * Highlights: This enhancement affects existing commands and commands to be added in future. It required an in-depth analysis of design alternatives. The implementation too was challenging as it required changes to existing commands.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":16,"author":{"gitId":"yellowbrickkode"},"content":"  * Credits: *{mention here if you reused any code/ideas from elsewhere or if a third-party library is heavily used in the feature so that a reader can make a more accurate judgement of how much effort went into the feature}*","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":17,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":18,"author":{"gitId":"yellowbrickkode"},"content":"* **New Feature**: Added a history command that allows the user to navigate to previous commands using up/down keys.","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":19,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":20,"author":{"gitId":"yellowbrickkode"},"content":"* **Code contributed**: [RepoSense link]()","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":21,"author":{"gitId":"yellowbrickkode"},"content":"","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":22,"author":{"gitId":"yellowbrickkode"},"content":"* **Project management**:","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":23,"author":{"gitId":"yellowbrickkode"},"content":"  * Managed releases `v1.3` - `v1.5rc` (3 releases) on GitHub","lastModifiedDate":"2026-02-28T10:28:12","isFullCredit":false},{"lineNumber":24,"author":{"gitId":"yellowb