cords, including","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":13,"author":{"gitId":"teleifo"},"content":"patient details, doctor information, diagnoses, and prescriptions. ClinicBook aims to","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":14,"author":{"gitId":"teleifo"},"content":"simplify clinic workflows by providing a lightweight and easy-to-learn system for managing","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":15,"author":{"gitId":"teleifo"},"content":"clinic data efficiently.","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":16,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":17,"author":{"gitId":"teleifo"},"content":"## Installation","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":18,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":19,"author":{"gitId":"teleifo"},"content":"___","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":20,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":21,"author":{"gitId":"teleifo"},"content":"1. Ensure that **Java 17 or later** is installed on your computer.\u003cbr\u003e","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":22,"author":{"gitId":"teleifo"},"content":"   **Mac users:** Make sure you install the exact JDK version specified [here](https://se-education.org/guides/tutorials/javaInstallationMac.html).","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":23,"author":{"gitId":"teleifo"},"content":"2. Download the latest `.jar` release from the [releases page](https://github.com/AY2526S2-CS2103-T11-3/tp/releases).","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":24,"author":{"gitId":"teleifo"},"content":"3. Copy the downloaded `.jar` file to the folder you want to use as the application\u0027s home directory.","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":25,"author":{"gitId":"teleifo"},"content":"4. Open a command terminal and navigate to that folder using `cd`.","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":26,"author":{"gitId":"teleifo"},"content":"5. Run the following command to start the application: `java -jar clinicbook.jar`.","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":27,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":28,"author":{"gitId":"teleifo"},"content":"The application\u0027s GUI should appear after a few seconds.","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":29,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":30,"author":{"gitId":"teleifo"},"content":"## Acknowledgements","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":31,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":32,"author":{"gitId":"teleifo"},"content":"___","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":33,"author":{"gitId":"teleifo"},"content":"","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false},{"lineNumber":34,"author":{"gitId":"teleifo"},"content":"This project is based on the AddressBook-Level3 project created by the [SE-EDU initiative](https://se-education.org).","lastModifiedDate":"2026-03-06T01:06:05","isFullCredit":false}],"authorContributionMap":{"teleifo":31,"-":3}},{"path":"docs/AboutUs.md","fileType":"docs","lines":[{"lineNumber":1,"author":{"gitId":"-"},"content":"---","lastModifiedDate":"2020-05-23T01:10:16","isFullCredit":false},{"